# ========================
# Sentinel Hook - .gitignore (Ultra-Clean)
# ========================

# ---- Node.js / Vite ----
node_modules/
dist/
dist-ssr/
*.local
web_ui/dist/
web_ui/node_modules/

# ---- Rust (Cargo) ----
target/
**/target/
Cargo.lock
sentinel-rust/target/

# ---- Python & Frida ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.dylib
.venv/
venv/
env/
# Projemizin ürettiği devasa geçici paket
_sentinel_bundle.js

# ---- macOS / System ----
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
*.swp
*.swo

# ---- IDE (VSCode / JetBrains) ----
.vscode/
.idea/
*.xcworkspace/
*.xcuserdata/
.history/

# ---- Logs & Temp ----
logs/
*.log
npm-debug.log*
tmp/
temp/
/Users/kadirarici/.gemini/

# ---- Secrets (Güvenlik) ----
.env
.env.*.local
*.pem
*.key
*.cert
.git_backup_safe/
time_machine.py
README 2.md
